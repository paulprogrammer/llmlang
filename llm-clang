#!/bin/bash
# llm-clang - A wrapper to integrate llmlang with clang

# Path to the llmlang compiler
if command -v llmlang >/dev/null 2>&1; then
    LLMLANG_BIN="llmlang"
else
    LLMLANG_BIN="$(dirname "$0")/target/release/llmlang"
    
    if [ ! -f "$LLMLANG_BIN" ]; then
        # Fallback to debug if release isn't built
        LLMLANG_BIN="$(dirname "$0")/target/debug/llmlang"
    fi
fi

if ! command -v "$LLMLANG_BIN" >/dev/null 2>&1 && [ ! -f "$LLMLANG_BIN" ]; then
    echo "Error: llmlang binary not found in PATH or at repo build locations."
    exit 1
fi

args=("$@")
processed_args=()
compiler_args=()
tmp_files=()

# Extract compiler-specific flags
i=0
while [ $i -lt ${#args[@]} ]; do
    arg="${args[$i]}"
    case "$arg" in
        --parallel|--threads|--queue|--config|-c)
            compiler_args+=("$arg")
            i=$((i + 1))
            compiler_args+=("${args[$i]}")
            ;;
        *.llm)
            # Handled in the next loop
            processed_args+=("$arg")
            ;;
        *)
            processed_args+=("$arg")
            ;;
    esac
    i=$((i + 1))
done

# We need to re-process because of the weird way clang-wrapper works
final_args=()
for arg in "${processed_args[@]}"; do
    if [[ "$arg" == *.llm ]]; then
        # Create a temporary object file
        obj="${arg%.llm}.o"
        "$LLMLANG_BIN" "$arg" "${compiler_args[@]}" -o "$obj"
        if [ $? -ne 0 ]; then
            echo "Error: llmlang failed to compile $arg"
            exit 1
        fi
        final_args+=("$obj")
        tmp_files+=("$obj")
    else
        final_args+=("$arg")
    fi
done

# Path to the runtime
RT_DIR="$(dirname "$0")/src/runtime"
RT_OBJ_DIR="$(dirname "$0")/target/runtime"
mkdir -p "$RT_OBJ_DIR"

# Compile all C runtime files
for c_file in "$RT_DIR"/*.c; do
    obj_file="$RT_OBJ_DIR/$(basename "$c_file" .c).o"
    if [ "$c_file" -nt "$obj_file" ]; then
        clang -c "$c_file" -o "$obj_file" -I"$RT_DIR"
    fi
done

# Call clang to link the object files including all runtime objects
clang "${final_args[@]}" "$RT_OBJ_DIR"/*.o -lpthread
LINK_RET=$?

# If the user didn't specify -c, we might want to cleanup .o files?
# Clang usually does this if it handles the whole pipeline.
# For this wrapper, we'll keep them to match clang behavior when passing .o files.

exit $LINK_RET
