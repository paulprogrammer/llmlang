#!/bin/bash
# llm-clang - A wrapper to integrate llmlang with clang

# -u is deliberately omitted: macOS ships bash 3.2, where expanding an empty
# array ("${arr[@]}") trips `set -u`.
set -eo pipefail

# Path to the llmlang compiler
if command -v llmlang >/dev/null 2>&1; then
    LLMLANG_BIN="llmlang"
else
    REL_BIN="$(dirname "$0")/target/release/llmlang"
    DEB_BIN="$(dirname "$0")/target/debug/llmlang"
    
    if [ -f "$REL_BIN" ] && [ -f "$DEB_BIN" ]; then
        if [ "$REL_BIN" -nt "$DEB_BIN" ]; then
            LLMLANG_BIN="$REL_BIN"
        else
            LLMLANG_BIN="$DEB_BIN"
        fi
    elif [ -f "$REL_BIN" ]; then
        LLMLANG_BIN="$REL_BIN"
    else
        LLMLANG_BIN="$DEB_BIN"
    fi
fi

if ! command -v "$LLMLANG_BIN" >/dev/null 2>&1 && [ ! -f "$LLMLANG_BIN" ]; then
    echo "Error: llmlang binary not found in PATH or at repo build locations."
    exit 1
fi

args=("$@")
processed_args=()
compiler_args=()
tmp_files=()
compile_only=false
debug_flags=""
output_file=""
llm_files=()

# Extract compiler-specific flags and inputs
i=0
while [ $i -lt ${#args[@]} ]; do
    arg="${args[$i]}"
    case "$arg" in
        --parallel|--threads|--queue|--config|-I)
            compiler_args+=("$arg")
            i=$((i + 1))
            compiler_args+=("${args[$i]}")
            ;;
        -c)
            compile_only=true
            ;;
        -o)
            i=$((i + 1))
            output_file="${args[$i]}"
            ;;
        -g)
            debug_flags="-g"
            processed_args+=("$arg")
            ;;
        *.llm)
            llm_files+=("$arg")
            ;;
        *)
            processed_args+=("$arg")
            ;;
    esac
    i=$((i + 1))
done

if [ "$compile_only" = true ]; then
    if [ ${#llm_files[@]} -eq 1 ] && [ -n "$output_file" ]; then
        # Single file compilation with explicit output object name
        "$LLMLANG_BIN" "${llm_files[0]}" "${compiler_args[@]}" -o "$output_file"
        exit $?
    else
        # Multiple files or default output names
        for llm_file in "${llm_files[@]}"; do
            obj="${llm_file%.llm}.o"
            "$LLMLANG_BIN" "$llm_file" "${compiler_args[@]}" -o "$obj"
        done
        exit 0
    fi
fi

# Build final arguments list for the linking stage
final_args=()
for arg in "${processed_args[@]}"; do
    final_args+=("$arg")
done

# Compile LLM files to temporary object files for linking
for llm_file in "${llm_files[@]}"; do
    obj="${llm_file%.llm}.o"
    if ! "$LLMLANG_BIN" "$llm_file" "${compiler_args[@]}" -o "$obj"; then
        echo "Error: llmlang failed to compile $llm_file" >&2
        exit 1
    fi
    final_args+=("$obj")
    tmp_files+=("$obj")
done

# Pass the output file target to clang if specified
if [ -n "$output_file" ]; then
    final_args+=("-o" "$output_file")
fi

# Path to the runtime
RT_DIR="$(dirname "$0")/src/runtime"
RT_OBJ_DIR="$(dirname "$0")/target/runtime"
mkdir -p "$RT_OBJ_DIR"

# Check build mode to prevent linking stale object files
build_mode="release"
if [ -n "$debug_flags" ]; then
    build_mode="debug"
fi

if [ -f "$RT_OBJ_DIR/.build_mode" ]; then
    last_mode=$(cat "$RT_OBJ_DIR/.build_mode")
else
    last_mode=""
fi

if [ "$build_mode" != "$last_mode" ]; then
    rm -f "$RT_OBJ_DIR"/*.o
    echo "$build_mode" > "$RT_OBJ_DIR/.build_mode"
fi

# Determine extra flags for macOS (Homebrew prefixes)
EXTRA_CFLAGS=""
EXTRA_LDFLAGS=""
if [ "$(uname -s)" = "Darwin" ]; then
    if command -v brew >/dev/null 2>&1; then
        BREW_PREFIX="$(brew --prefix)"
        MBEDTLS_PREFIX="$(brew --prefix mbedtls@3 2>/dev/null || echo "$BREW_PREFIX/opt/mbedtls@3")"
        EXTRA_CFLAGS="-I$MBEDTLS_PREFIX/include -I$BREW_PREFIX/include"
        EXTRA_LDFLAGS="-L$MBEDTLS_PREFIX/lib -L$BREW_PREFIX/lib"
    else
        # No brew on PATH: fall back to the standard Homebrew locations
        EXTRA_CFLAGS="-I/opt/homebrew/opt/mbedtls@3/include -I/usr/local/opt/mbedtls@3/include -I/opt/homebrew/include -I/usr/local/include"
        EXTRA_LDFLAGS="-L/opt/homebrew/opt/mbedtls@3/lib -L/usr/local/opt/mbedtls@3/lib -L/opt/homebrew/lib -L/usr/local/lib"
    fi
fi

# Compile all C runtime files. A failed compile must abort the link:
# proceeding would silently link a stale object from a previous build.
for c_file in "$RT_DIR"/*.c; do
    obj_file="$RT_OBJ_DIR/$(basename "$c_file" .c).o"
    if [ "$c_file" -nt "$obj_file" ] || [ "$RT_DIR/common.h" -nt "$obj_file" ]; then
        if ! clang $debug_flags -fPIC -c "$c_file" -o "$obj_file" -I"$RT_DIR" $EXTRA_CFLAGS; then
            echo "Error: failed to compile runtime file $(basename "$c_file")" >&2
            rm -f "$obj_file"
            exit 1
        fi
    fi
done

# Package runtime objects into a static archive
if ! ar rcs "$RT_OBJ_DIR/libllm_rt.a" "$RT_OBJ_DIR"/*.o; then
    echo "Error: failed to archive runtime objects into libllm_rt.a" >&2
    exit 1
fi

# Compile OpenCL dynamic library plugin if present
if [ -f "$RT_DIR/driver_src/opencl_driver.c" ]; then
    if [ "$RT_DIR/driver_src/opencl_driver.c" -nt "$RT_OBJ_DIR/libllm_opencl.so" ]; then
        clang $debug_flags -fPIC -shared "$RT_DIR/driver_src/opencl_driver.c" -o "$RT_OBJ_DIR/libllm_opencl.so" -I"$RT_DIR" -ldl
    fi
    # The runtime dlopens this from the working directory; only refresh the
    # copy when it is missing or stale instead of clobbering it on every link.
    if [ ! -f ./libllm_opencl.so ] || [ "$RT_OBJ_DIR/libllm_opencl.so" -nt ./libllm_opencl.so ]; then
        cp -f "$RT_OBJ_DIR/libllm_opencl.so" .
    fi
fi

# Call clang to link the object files including the runtime static archive.
# Capture the status without tripping set -e so temp objects still get cleaned.
LINK_RET=0
if [ "$(uname -s)" = "Darwin" ]; then
    clang "${final_args[@]}" -Wl,-force_load,"$RT_OBJ_DIR/libllm_rt.a" -lpthread -lcurl -lmbedtls -lmbedx509 -lmbedcrypto -lsqlite3 $EXTRA_LDFLAGS || LINK_RET=$?
else
    clang "${final_args[@]}" -Wl,--whole-archive -L"$RT_OBJ_DIR" -lllm_rt -Wl,--no-whole-archive -Wl,--as-needed -lpthread -ldl -lcurl -lmbedtls -lmbedx509 -lmbedcrypto -lsqlite3 -Wl,--no-as-needed || LINK_RET=$?
fi

# Clean up transient intermediate object files
for tmp in "${tmp_files[@]}"; do
    rm -f "$tmp"
done

exit $LINK_RET
