// HTTP Native Client Test

: main
    L url_get "http://127.0.0.1:8080/get"
    L res_get http "GET" $ url_get ""
    . ? sr $ res_get "Hello.*" 0 ! "GET response mismatch"

    L url_post "http://127.0.0.1:8080/post"
    L body "Hello World"
    L res_post http "POST" $ url_post $ body
    . ? sr $ res_post "Echo: Hello World" 0 ! "POST response mismatch"
    0
