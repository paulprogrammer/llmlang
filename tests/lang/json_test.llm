// JSON Library Test

I json parse
I json stringify
I json get_int
I json get_str
I json get_obj
I json get_arr
I json arr_len
I json arr_get

: main
    L raw_json "{\"code\":200,\"status\":\"ok\",\"data\":{\"user\":\"Alice\",\"hobbies\":[\"reading\",\"coding\"]}}"

    // Bind keys to variables to ensure zero leaks in Valgrind (affine type auto-drop)
    L k_code "code"
    L k_status "status"
    L k_ok "ok"
    L k_data "data"
    L k_user "user"
    L k_alice "Alice"
    L k_hobbies "hobbies"
    L k_reading "\"reading\""
    L k_coding "\"coding\""

    // Parse the JSON
    L root @1 parse $ raw_json

    // Check root values
    L code @2 get_int $ root $ k_code
    . ? = code 200 0 ! "code mismatch"

    L status @2 get_str $ root $ k_status
    . ? sr $ status $ k_ok 0 ! "status mismatch"

    // Get nested data object
    L data @2 get_obj $ root $ k_data
    . ? = data 0 ! "missing data object" 0

    L user @2 get_str data $ k_user
    . ? sr $ user $ k_alice 0 ! "user mismatch"

    // Get hobbies array
    L hobbies @2 get_arr data $ k_hobbies
    . ? = hobbies 0 ! "missing hobbies array" 0

    L len @1 arr_len hobbies
    . ? = len 2 0 ! "hobbies length mismatch"

    L h0_val @2 arr_get hobbies 0
    L h0 @1 stringify h0_val
    . ? sr $ h0 $ k_reading 0 ! "hobby 0 mismatch"

    L h1_val @2 arr_get hobbies 1
    L h1 @1 stringify h1_val
    . ? sr $ h1 $ k_coding 0 ! "hobby 1 mismatch"

    0
