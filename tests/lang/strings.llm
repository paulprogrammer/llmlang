// String Operations

: main
    L s1 "Hello "
    L s2 "World"
    L s3 sc $ s1 $ s2
    . ? sr $ s3 "^Hello.*" 0 ! "Regex match failed"
    . ? = sl $ s3 11 0 ! "Length failed"
    . ? = sf $ s3 "World" 6 0 ! "Loc failed"
    L sub ss > s3 0 5
    . ? sr > sub "Hello" 0 ! "Sub failed"
    L csv "a,b,c"
    ? sr sp $ csv "," 1 "b"
        0
        ! "Split failed"
