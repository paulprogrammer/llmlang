// json_test.llm
# User id age

: main
    L u N User 2
    . S $ u id 0 101
    . S $ u id 1 102
    . S $ u age 0 30
    . S $ u age 1 40
    
    L json jp $ u
    . ) 1 sc "Serialized: " sc $ json "\n"
    
    L u2 ju > json "User"
    . ) 1 sc "Unpacked ID 0: " sc str G $ u2 id 0 "\n"
    . ) 1 sc "Unpacked ID 1: " sc str G $ u2 id 1 "\n"
    . ) 1 sc "Unpacked Age 0: " sc str G $ u2 age 0 "\n"
    ) 1 sc "Unpacked Age 1: " sc str G > u2 age 1 "\n"
