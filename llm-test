#!/bin/bash
# llm-test - A simple test runner for pure llmlang tests

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

PASSED=0
FAILED=0
TEST_FILES=()
OTHER_ARGS=()

for arg in "$@"; do
    if [[ "$arg" == *.llm ]]; then
        TEST_FILES+=("$arg")
    elif [[ -f "$arg" ]]; then
        TEST_FILES+=("$arg")
    else
        OTHER_ARGS+=("$arg")
    fi
done

if [ ${#TEST_FILES[@]} -eq 0 ]; then
    TEST_FILES=(tests/lang/*.llm)
fi

echo "Running llmlang self-hosted tests..."
echo "------------------------------------"

# 1. Compile Libraries (files without : main)
LIBS=()
APPS=()

for f in "${TEST_FILES[@]}"; do
    if grep -q ": main" "$f"; then
        APPS+=("$f")
    else
        LIBS+=("$f")
    fi
done

LIB_OBJS=()
for lib in "${LIBS[@]}"; do
    obj="${lib%.llm}.o"
    ./llm-clang -c "$lib" "${OTHER_ARGS[@]}" -o "$obj"
    if [ $? -eq 0 ]; then
        LIB_OBJS+=("$obj")
    else
        echo -e "${RED}[FAIL]${NC} $(basename "$lib") (Library compilation failed)"
        FAILED=$((FAILED + 1))
    fi
done

# 2. Run Applications
for test_file in "${APPS[@]}"; do
    test_name=$(basename "$test_file")
    bin_name="${test_file%.llm}_bin"
    
    ./llm-clang "$test_file" "${LIB_OBJS[@]}" "${OTHER_ARGS[@]}" -o "$bin_name"
    
    if [ $? -ne 0 ]; then
        echo -e "${RED}[FAIL]${NC} $test_name (Compilation failed)"
        FAILED=$((FAILED + 1))
        continue
    fi
    
    ./"$bin_name"
    exit_code=$?
    
    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}[PASS]${NC} $test_name"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}[FAIL]${NC} $test_name (Exit code: $exit_code)"
        FAILED=$((FAILED + 1))
    fi
    
    rm -f "$bin_name"
done

# Cleanup library objects and signatures
rm -f tests/lang/*.o tests/lang/*.llmi

echo "------------------------------------"
echo -e "Summary: ${GREEN}$PASSED passed${NC}, ${RED}$FAILED failed${NC}"

if [ $FAILED -gt 0 ]; then
    exit 1
fi
