#!/bin/bash
# llm-test - A simple test runner for pure llmlang tests

# Individual test failures are tolerated (counted via if-guards below);
# -e catches unexpected runner breakage. -u is omitted: macOS bash 3.2
# trips on empty-array expansion under set -u.
set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

PASSED=0
FAILED=0
TEST_FILES=()
OTHER_ARGS=()

for arg in "$@"; do
    if [[ "$arg" == *.llm ]]; then
        TEST_FILES+=("$arg")
    elif [[ -f "$arg" ]]; then
        TEST_FILES+=("$arg")
    else
        OTHER_ARGS+=("$arg")
    fi
done

if [ ${#TEST_FILES[@]} -eq 0 ]; then
    TEST_FILES=()
    for f in tests/lang/*.llm; do
        if [[ "$(basename "$f")" != "http_server_test.llm" ]] && [[ "$(basename "$f")" != "https_test.llm" ]] && [[ "$(basename "$f")" != "http_router_test.llm" ]] && [[ "$(basename "$f")" != "http_dynamic_router_test.llm" ]] && [[ "$(basename "$f")" != "http_headers_test.llm" ]] && [[ "$(basename "$f")" != "http_db_test.llm" ]] && [[ "$(basename "$f")" != "patch_test.llm" ]] && [[ "$(basename "$f")" != "stdin_multiline_test.llm" ]]; then
            TEST_FILES+=("$f")
        fi
    done
fi

# Always include lib/*.llm and -I lib for imports
OTHER_ARGS+=("-I" "lib")
for f in lib/*.llm; do
    if [ -f "$f" ]; then
        found=false
        for tf in "${TEST_FILES[@]}"; do
            if [[ "$tf" == "$f" ]]; then
                found=true
                break
            fi
        done
        if [ "$found" = false ]; then
            TEST_FILES+=("$f")
        fi
    fi
done

# Mock server errors (e.g. port 8080 already bound by a concurrent run) land
# here instead of being swallowed, and are printed if startup fails.
MOCK_LOG="$(mktemp)"

# Start background mock HTTP server for standard library testing.
# ThreadingHTTPServer + a per-connection timeout so a stray idle connection
# (e.g. a port prober on CI runners) cannot wedge the accept loop and stall
# real requests behind it.
python3 -c '
from http.server import ThreadingHTTPServer, BaseHTTPRequestHandler
from urllib.parse import parse_qsl
import json
class Handler(BaseHTTPRequestHandler):
    timeout = 5
    def log_message(self, format, *args):
        pass
    def _send(self, body, ctype="text/plain"):
        self.send_response(200)
        self.send_header("Content-Type", ctype)
        self.end_headers()
        self.wfile.write(body)
    def do_GET(self):
        if self.path == "/json/get":
            # httpbin.org/get-style JSON echo, so JSON-parsing tests do not
            # need the live internet
            self._send(json.dumps({"url": "http://127.0.0.1:8080/json/get",
                                   "args": {}}).encode(), "application/json")
        else:
            self._send(b"Hello from local mock server")
    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(content_length)
        if self.path == "/json/post":
            # httpbin.org/post-style JSON echo: form-encoded body -> "form"
            form = dict(parse_qsl(body.decode("utf-8", "replace"), keep_blank_values=True))
            self._send(json.dumps({"form": form,
                                   "url": "http://127.0.0.1:8080/json/post"}).encode(), "application/json")
        else:
            self._send(b"Echo: " + body)
server = ThreadingHTTPServer(("127.0.0.1", 8080), Handler)
server.daemon_threads = True
server.serve_forever()
' >"$MOCK_LOG" 2>&1 &
MOCK_PID=$!

cleanup() {
    kill $MOCK_PID >/dev/null 2>&1 || true
    wait $MOCK_PID >/dev/null 2>&1 || true
    rm -f "$MOCK_LOG" tests/lang/*.o tests/lang/*.llmi
}
trap cleanup EXIT

# Wait until the mock server is actually answering requests (up to 10s)
SERVER_READY=false
for _ in $(seq 1 40); do
    if curl -s --max-time 1 http://127.0.0.1:8080/ 2>/dev/null | grep -q "Hello from local mock server"; then
        SERVER_READY=true
        break
    fi
    sleep 0.25
done
if [ "$SERVER_READY" = false ]; then
    echo "ERROR: mock HTTP server on 127.0.0.1:8080 is not responding." >&2
    echo "Is another llm-test run (or something else) holding the port?" >&2
    echo "--- server output ---" >&2
    cat "$MOCK_LOG" >&2 || true
    echo "--- port state ---" >&2
    lsof -nP -i :8080 2>/dev/null >&2 || true
    exit 1
fi

echo "Running llmlang self-hosted tests..."
echo "------------------------------------"

# 1. Compile Libraries (files without : main)
LIBS=()
APPS=()

for f in "${TEST_FILES[@]}"; do
    if grep -q ": main" "$f"; then
        APPS+=("$f")
    else
        LIBS+=("$f")
    fi
done

LIB_OBJS=()
for lib in "${LIBS[@]}"; do
    obj="${lib%.llm}.o"
    if ./llm-clang -c "$lib" "${OTHER_ARGS[@]}" -o "$obj"; then
        LIB_OBJS+=("$obj")
    else
        echo -e "${RED}[FAIL]${NC} $(basename "$lib") (Library compilation failed)"
        FAILED=$((FAILED + 1))
    fi
done

# 2. Run Applications
for test_file in "${APPS[@]}"; do
    test_name=$(basename "$test_file")
    bin_name="${test_file%.llm}_bin"
    
    if ! ./llm-clang "$test_file" "${LIB_OBJS[@]}" "${OTHER_ARGS[@]}" -o "$bin_name"; then
        echo -e "${RED}[FAIL]${NC} $test_name (Compilation failed)"
        FAILED=$((FAILED + 1))
        continue
    fi

    if ./"$bin_name"; then
        exit_code=0
    else
        exit_code=$?
    fi

    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}[PASS]${NC} $test_name"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}[FAIL]${NC} $test_name (Exit code: $exit_code)"
        FAILED=$((FAILED + 1))
    fi
    
    rm -f "$bin_name"
done

# 3. Raw-fd stdin regression test: needs piped input, so it is excluded
# from the plain loop above and run here with three lines on stdin.
STDIN_TEST="tests/lang/stdin_multiline_test.llm"
if [ -f "$STDIN_TEST" ]; then
    bin_name="${STDIN_TEST%.llm}_bin"
    if ./llm-clang "$STDIN_TEST" "${OTHER_ARGS[@]}" -o "$bin_name" \
        && printf 'alpha\nbeta\ngamma\n' | ./"$bin_name"; then
        echo -e "${GREEN}[PASS]${NC} $(basename "$STDIN_TEST") (piped stdin)"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}[FAIL]${NC} $(basename "$STDIN_TEST")"
        FAILED=$((FAILED + 1))
    fi
    rm -f "$bin_name"
fi

# 4. Runtime C unit tests (thread-safety of the managed-object refcount)
RT_RACE_TEST="tests/runtime/refcount_race_test.c"
if [ -f "$RT_RACE_TEST" ]; then
    bin_name="tests/runtime/refcount_race_test_bin"
    if clang -O2 "$RT_RACE_TEST" src/runtime/memory.c -Isrc/runtime -lpthread -o "$bin_name" \
        && ./"$bin_name" >/dev/null; then
        echo -e "${GREEN}[PASS]${NC} refcount_race_test.c"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}[FAIL]${NC} refcount_race_test.c"
        FAILED=$((FAILED + 1))
    fi
    rm -f "$bin_name"
fi

# Cleanup library objects and signatures
rm -f tests/lang/*.o tests/lang/*.llmi

echo "------------------------------------"
echo -e "Summary: ${GREEN}$PASSED passed${NC}, ${RED}$FAILED failed${NC}"

if [ $FAILED -gt 0 ]; then
    exit 1
fi
exit 0
