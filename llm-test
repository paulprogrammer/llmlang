#!/bin/bash
# llm-test - A simple test runner for pure llmlang tests

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

PASSED=0
FAILED=0
TEST_FILES=()
OTHER_ARGS=()

for arg in "$@"; do
    if [[ "$arg" == *.llm ]]; then
        TEST_FILES+=("$arg")
    elif [[ -f "$arg" ]]; then
        TEST_FILES+=("$arg")
    else
        OTHER_ARGS+=("$arg")
    fi
done

if [ ${#TEST_FILES[@]} -eq 0 ]; then
    TEST_FILES=()
    for f in tests/lang/*.llm; do
        if [[ "$(basename "$f")" != "http_server_test.llm" ]] && [[ "$(basename "$f")" != "https_test.llm" ]] && [[ "$(basename "$f")" != "http_router_test.llm" ]] && [[ "$(basename "$f")" != "http_dynamic_router_test.llm" ]] && [[ "$(basename "$f")" != "http_headers_test.llm" ]]; then
            TEST_FILES+=("$f")
        fi
    done
fi

# Always include lib/*.llm and -I lib for imports
OTHER_ARGS+=("-I" "lib")
for f in lib/*.llm; do
    if [ -f "$f" ]; then
        found=false
        for tf in "${TEST_FILES[@]}"; do
            if [[ "$tf" == "$f" ]]; then
                found=true
                break
            fi
        done
        if [ "$found" = false ]; then
            TEST_FILES+=("$f")
        fi
    fi
done

# Start background mock HTTP server for standard library testing
python3 -c '
from http.server import HTTPServer, BaseHTTPRequestHandler
class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        pass
    def do_GET(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.end_headers()
        self.wfile.write(b"Hello from local mock server")
    def do_POST(self):
        content_length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(content_length)
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.end_headers()
        self.wfile.write(b"Echo: " + body)
server = HTTPServer(("127.0.0.1", 8080), Handler)
server.serve_forever()
' >/dev/null 2>&1 &
MOCK_PID=$!

cleanup() {
    kill $MOCK_PID >/dev/null 2>&1
    wait $MOCK_PID >/dev/null 2>&1
    rm -f tests/lang/*.o tests/lang/*.llmi
}
trap cleanup EXIT

# Wait a brief moment for the server to bind
sleep 0.5

echo "Running llmlang self-hosted tests..."
echo "------------------------------------"

# 1. Compile Libraries (files without : main)
LIBS=()
APPS=()

for f in "${TEST_FILES[@]}"; do
    if grep -q ": main" "$f"; then
        APPS+=("$f")
    else
        LIBS+=("$f")
    fi
done

LIB_OBJS=()
for lib in "${LIBS[@]}"; do
    obj="${lib%.llm}.o"
    ./llm-clang -c "$lib" "${OTHER_ARGS[@]}" -o "$obj"
    if [ $? -eq 0 ]; then
        LIB_OBJS+=("$obj")
    else
        echo -e "${RED}[FAIL]${NC} $(basename "$lib") (Library compilation failed)"
        FAILED=$((FAILED + 1))
    fi
done

# 2. Run Applications
for test_file in "${APPS[@]}"; do
    test_name=$(basename "$test_file")
    bin_name="${test_file%.llm}_bin"
    
    ./llm-clang "$test_file" "${LIB_OBJS[@]}" "${OTHER_ARGS[@]}" -o "$bin_name"
    
    if [ $? -ne 0 ]; then
        echo -e "${RED}[FAIL]${NC} $test_name (Compilation failed)"
        FAILED=$((FAILED + 1))
        continue
    fi
    
    ./"$bin_name"
    exit_code=$?
    
    if [ $exit_code -eq 0 ]; then
        echo -e "${GREEN}[PASS]${NC} $test_name"
        PASSED=$((PASSED + 1))
    else
        echo -e "${RED}[FAIL]${NC} $test_name (Exit code: $exit_code)"
        FAILED=$((FAILED + 1))
    fi
    
    rm -f "$bin_name"
done

# Cleanup library objects and signatures
rm -f tests/lang/*.o tests/lang/*.llmi

echo "------------------------------------"
echo -e "Summary: ${GREEN}$PASSED passed${NC}, ${RED}$FAILED failed${NC}"

if [ $FAILED -gt 0 ]; then
    exit 1
fi
