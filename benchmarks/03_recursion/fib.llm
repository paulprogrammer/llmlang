// Fibonacci Benchmark (llmlang)

: fib n
    ? < $ n 2
        $ n
        + @1 fib - $ n 1 @1 fib - $ n 2

: main
    L n 40
    L start tns
    L result @1 fib $ n
    L end tns

    . ) 1 sc "Fib(" sc str > n sc ") = " sc str > result "\n"
    . ) 1 sc "Fib Time: " sc str / - $ end $ start 1000000 "ms\n"
    0
