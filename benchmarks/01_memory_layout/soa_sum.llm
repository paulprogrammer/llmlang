// SoA Benchmark (llmlang) - High Precision
# Vector id x y z

: init_loop i v c
    ? < $ i $ c
        . S $ v id $ i $ i
        . S $ v x $ i 1
        . S $ v y $ i 2
        . S $ v z $ i 3
        @3 init_loop + $ i 1 $ v $ c
        0

: sum_loop i v c acc
    ? < $ i $ c
        @4 sum_loop + $ i 1 $ v $ c + $ acc G $ v x $ i
        $ acc

: main
    L count 2000000
    L v N Vector $ count
    
    L start_init tns
    L dummy1 @3 init_loop 0 $ v $ count
    L end_init tns
    . ) 1 sc "Init Time: " sc str / - $ end_init $ start_init 1000000 "ms\n"

    L start_sum tns
    L total @4 sum_loop 0 $ v $ count 0
    L end_sum tns
    
    . ) 1 sc "Sum: " sc str > total "\n"
    . ) 1 sc "Sum Time: " sc str / - $ end_sum $ start_sum 1000000 "ms\n"
    
    0
